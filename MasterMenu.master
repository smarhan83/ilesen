            <!-- START LOGIN BOX -->

			<!-- Login Section -->
            <div class="modal fade" id="loginModal" tabindex="-1" aria-hidden="true">

            <div class="modal-dialog modal-dialog-centered modal-lg">

                <div class="modal-content border-0 shadow-lg">

                    <div class="modal-body p-0">


                           
                    <div class="row g-0">

                 

                      <!-- Right Side - Login Form -->
                      <div class="col-lg-7 p-5 bg-white">


                        <!-- Login Form -->
                        <div runat="server" id="myForm">

                        <div class="mb-4">
                          <h1 class="mb-2" style="font-size: 28px; font-weight: 900; color: var(--text);">Log Masuk</h1>
                          <p class="text-muted mb-4">Sila masukkan maklumat akaun anda</p>

                        </div>
              
                          <!-- ID Pengguna Field -->
                          <div class="mb-3">
                            <label for="txtUsername" class="form-label" style="font-weight: 600;">ID Pengguna</label>

                            <div class="modern-input">
                                <i class="bi bi-person-circle input-icon"></i>

                                <asp:TextBox
                                    ID="txtUsername"
                                    runat="server"
                                    CssClass="form-control custom-input"
                                    placeholder="Cth: 910101014321 (tanpa '-')">
                                </asp:TextBox>
                            </div>
                            <asp:RequiredFieldValidator ID="RequiredFieldValidator3" runat="server"
                                                       ValidationGroup="loginForm"
                                                       ControlToValidate="txtUsername" 
                                                       ErrorMessage="Sila masukkan ID Pengguna" 
                                                       Display="Dynamic"
                                                       CssClass="text-danger small mt-1"></asp:RequiredFieldValidator>
                            <%--<asp:ValidatorCalloutExtender ID="ce1" runat="server" TargetControlID="RequiredFieldValidator3">
                            </asp:ValidatorCalloutExtender>--%>
                          </div>

                          <!-- Password Field -->
                          <div class="mb-3">
                            <label for="txtPassword" class="form-label" style="font-weight: 600;">Katalaluan</label>
                            <div class="modern-input">
                                <i class="bi bi-lock-fill input-icon"></i>

                                <asp:TextBox
                                    ID="txtPassword"
                                    runat="server"
                                    TextMode="Password"
                                    CssClass="form-control custom-input"
                                    placeholder="Masukkan katalaluan anda">
                                </asp:TextBox>

                                <button type="button" id="togglePassword" class="eye-btn">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            <asp:RequiredFieldValidator ID="RequiredFieldValidator2" runat="server"
                                                       ValidationGroup="loginForm"
                                                       ControlToValidate="txtPassword" 
                                                       ErrorMessage="Sila masukkan katalaluan" 
                                                       Display="Dynamic"
                                                       CssClass="text-danger small mt-1"></asp:RequiredFieldValidator>
                            <%--<asp:ValidatorCalloutExtender ID="ce2" runat="server" TargetControlID="RequiredFieldValidator2">
                            </asp:ValidatorCalloutExtender>--%>
                          </div>

                          <!-- Remember Me & Forgot Password -->
                          <div class="d-flex justify-content-between align-items-center mb-4">
                            <%--<div class="form-check">
                              <input class="form-check-input" type="checkbox" id="rememberMe">
                              <label class="form-check-label text-muted" for="rememberMe" style="font-size: 13px;">
                                Ingat Saya
                              </label>
                            </div>--%>
                            <asp:LinkButton ID="lbFP" runat="server" CssClass="btn btn-link p-0" 
                                           style="color: var(--primary); text-decoration: none; font-weight: 600; font-size: 13px;">
                              Lupa Katalaluan?
                            </asp:LinkButton>
                          </div>

                          <!-- Login Button -->
                          <asp:Button ID="btnLogin" runat="server" Text="Log Masuk"
                                    ValidationGroup="loginForm"
                                     CssClass="btn btn-outline-primary w-100 mb-2" 
                                     Style="padding: 10px; font-weight: 700; border-radius: 8px;" />

              
                          <!-- Error Message -->
                      <%--  <asp:Label ID="txtError"
                            runat="server"
                            CssClass="alert alert-danger d-block mb-4"
                            Visible="false">
                        </asp:Label>--%>

                        <div class="text-center mb-3">
                        <asp:Label ID="txtError" runat="server" Text="" 
                                    CssClass="alert alert-danger d-inline-block px-3 py-2" 
                                    Style="display: none; font-size: 13px;" Visible="false"></asp:Label>
                        </div>

                        </div>

                        <!-- Forgot Password Form (Hidden by default) -->
                        <div runat="server" id="myCheckAcc" visible="false" class="fade-in">
                          <div class="mb-4">
                            <%--<button type="button" class="btn btn-link p-0 mb-4" id="backToLogin" 
                                   style="color: var(--primary); font-weight: 600;">
                              <i class="bi bi-arrow-left me-1"></i>Kembali ke Log Masuk
                            </button>--%>
                            <h1 class="mb-2" style="font-size: 24px; font-weight: 900;">Pengesahan Akaun</h1>
                            <p class="text-muted mb-4">Masukkan alamat email anda untuk memulihkan akaun</p>
                          </div>

                          <asp:FormView ID="fvFP" DefaultMode="Insert" Width="100%" runat="server" 
                                       DataKeyNames="farmerID" DataSourceID="SqlDataSourceForm">
                            <InsertItemTemplate>
                  
                              <!-- Email Field -->
                              <div class="mb-3">
                                <label for="Users_Email" class="form-label" style="font-weight: 600;">Alamat Email</label>
                                 <div class="modern-input">
                                    <i class="bi bi-envelope input-icon"></i>

                                    <asp:TextBox 
                                        AutoCompleteType="Disabled"
                                        ID="Users_Email"
                                        runat="server"
                                        CssClass="form-control custom-input"
                                        placeholder="Masukkan alamat email anda"
                                        aria-label="Alamat Email">
                                    </asp:TextBox>
                                </div>
                                <asp:RequiredFieldValidator ID="RequiredFieldValidator5" ControlToValidate="Users_Email" 
                                                           CssClass="text-danger small" runat="server" 
                                                           ErrorMessage="Sila masukkan alamat email!" 
                                                           ValidationGroup="insertForm" Display="Dynamic"></asp:RequiredFieldValidator>
                                <asp:RegularExpressionValidator ID="RegularExpressionValidator1" runat="server" 
                                                               CssClass="text-danger small"
                                                               ControlToValidate="Users_Email" 
                                                               ErrorMessage="Format email tidak sah"
                                                               ValidationExpression="\w+([-+.']\w+)*@\w+([-.]\w+)*\.\w+([-.]\w+)*"
                                                               ValidationGroup="insertForm" Display="Dynamic"></asp:RegularExpressionValidator>
                              </div>

                              <!-- Check Account Button -->
                              <asp:LinkButton ID="btnCheckAcc" runat="server" Text="Semak Akaun" 
                                             CssClass="btn btn-outline-primary w-100 mb-2"  
                                             Style="padding: 10px; font-weight: 700; border-radius: 8px;" 
                                             ValidationGroup="insertForm" CausesValidation="True" 
                                             OnClick="btnCheckAcc_Click"></asp:LinkButton>

                              <!-- Status Message -->
                              <div class="text-center mb-3">
                                <asp:Label ID="lblCheckAcc" runat="server" Text="" 
                                          CssClass="alert alert-info d-inline-block px-3 py-2" 
                                          Style="display: none; font-size: 13px;" Visible="false"></asp:Label>
                              </div>

                              <asp:HiddenField ID="hfRegID" runat="server" />

                              <!-- Email Verify Button -->
                              <asp:LinkButton ID="btnEmailVerify" Visible="false" runat="server" 
                                             Text="Hantar Semula Pautan Pengesahan" 
                                             CssClass="btn btn-outline-primary w-100 mb-2" 
                                             Style="padding: 10px; font-weight: 600; border-radius: 8px;" 
                                             ValidationGroup="insertForm" CausesValidation="True" 
                                             OnClick="btnEmailVerify_Click"></asp:LinkButton>

                              <!-- Email Reset Button -->
                              <asp:LinkButton ID="btnEmailReset" Visible="false" runat="server" 
                                             Text="Set Semula Katalaluan" 
                                             CssClass="btn btn-outline-primary w-100 mb-2" 
                                             Style="padding: 10px; font-weight: 700; border-radius: 8px;" 
                                             ValidationGroup="insertForm" CausesValidation="True" 
                                             OnClick="btnEmailReset_Click"></asp:LinkButton>

                                <asp:LinkButton 
                                    ID="btnBackLogin" 
                                    runat="server"
                                    Text="← Login Semula"
                                    CssClass="btn btn-link w-100"
                                    OnClick="btnBackLogin_Click"
                                    Style="font-weight:600; text-decoration:none;">
                                </asp:LinkButton>

                            </InsertItemTemplate>
                          </asp:FormView>

                          <asp:SqlDataSource runat="server" ID="SqlDataSourceForm" 
                                            ConnectionString='<%$ ConnectionStrings:webcon_ConnectionStr %>'
                                            InsertCommand="INSERT INTO TBL_USERS (Users_Name, Users_Fullname, Users_Password, Users_Email, Users_Enabled, Users_Register,Users_TelNo,Users_RegID,createdDate,estate_id,Users_Address) 
                                            VALUES (@Users_Email, @Users_Fullname, @Users_Password, @Users_Email, 0, 0,@Users_TelNo,@Users_RegID,getdate(),0,@Users_Address);
                                            SELECT @latestID = @@IDENTITY;
                                            INSERT INTO ECM_Buyers (Username,FullName,Email,Active,CreatorID,CreatedDt,LastModID,LastModDt,PhoneNo,UsersID)
                                            VALUES (@Users_Email,@Users_Fullname,@Users_Email,0,'regform',getdate(),'regform',getdate(),@Users_TelNo,@latestID);
                                            INSERT INTO TBL_USER_GROUPLIST (UGL_UGN_Id,UGL_Users_Id) VALUES (8,@latestID);">
                            <InsertParameters>
                              <asp:Parameter Name="latestID" Type="Int32" Direction="Output" />  
                              <asp:Parameter Name="Users_Name" />
                              <asp:Parameter Name="Users_Fullname" />
                              <asp:Parameter Name="Users_Password" />
                              <asp:Parameter Name="Users_Email" />
                              <asp:Parameter Name="Users_TelNo" />
                              <asp:Parameter Name="Users_RegID" />
                              <asp:Parameter Name="Users_Address" />
                            </InsertParameters>
                          </asp:SqlDataSource>

                        </div>

                      </div>

                    </div>
             
            
                            <!-- end bg-light -->

                        </div>

                    </div>

                </div>

            </div>

            <!-- JavaScript for Enhanced UX -->
            <script>
                // Toggle password visibility
                document.getElementById('togglePassword').addEventListener('click', function () {
                    const passwordField = document.getElementById('<%= txtPassword.ClientID %>');
                  const icon = this.querySelector('i');

                  if (passwordField.type === 'password') {
                      passwordField.type = 'text';
                      icon.classList.remove('bi-eye');
                      icon.classList.add('bi-eye-slash');
                  } else {
                      passwordField.type = 'password';
                      icon.classList.remove('bi-eye-slash');
                      icon.classList.add('bi-eye');
                  }
              });

                // Back to login from forgot password
                document.getElementById('backToLogin').addEventListener('click', function () {
                    document.getElementById('myForm').style.display = 'block';
                    document.getElementById('myCheckAcc').style.display = 'none';
                });

                // Show forgot password form
                document.getElementById('<%= lbFP.ClientID %>').addEventListener('click', function(e) {
                e.preventDefault();
                document.getElementById('myForm').style.display = 'none';
                document.getElementById('myCheckAcc').style.display = 'block';
              });

              // Remember me functionality
              document.getElementById('rememberMe').addEventListener('change', function() {
                if (this.checked) {
                  localStorage.setItem('rememberUsername', document.getElementById('<%= txtUsername.ClientID %>').value);
                } else {
                  localStorage.removeItem('rememberUsername');
                }
              });

              // Load remembered username on page load
              window.addEventListener('load', function() {
                const remembered = localStorage.getItem('rememberUsername');
                if (remembered) {
                  document.getElementById('<%= txtUsername.ClientID %>').value = remembered;
                      document.getElementById('rememberMe').checked = true;
                  }
              });
            </script>

            <style>
              .fade-in {
                animation: fadeIn 0.3s ease-in;
              }

              @keyframes fadeIn {
                from {
                  opacity: 0;
                  transform: translateY(10px);
                }
                to {
                  opacity: 1;
                  transform: translateY(0);
                }
              }

              .input-group-text {
                border: 1px solid rgba(17, 24, 39, 0.1) !important;
              }

              .form-control {
                border: 1px solid rgba(17, 24, 39, 0.1) !important;
                border-radius: 8px !important;
              }

              .form-control:focus {
                border-color: var(--primary) !important;
                box-shadow: 0 0 0 0.2rem rgba(45, 108, 223, 0.15) !important;
              }

              @media (max-width: 768px) {
                .rounded-start {
                  border-radius: 8px 0 0 8px !important;
                }
                .rounded-end {
                  border-radius: 0 8px 8px 0 !important;
                }
              }
            </style>
            <!-- END LOGIN BOX -->

        <%  End If %>

