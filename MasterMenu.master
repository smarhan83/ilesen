  <style>
    :root{
      --pastel-1:#EAF6FF; /* light blue */
      --pastel-2:#FFF1F5; /* light pink */
      --pastel-3:#F2FFF4; /* light green */
      --pastel-4:#FFF9E6; /* light yellow */
      --primary:#2D6CDF;
      --text:#1f2937;
      --muted:#6b7280;
      --card:#ffffff;
      --shadow: 0 10px 30px rgba(16, 24, 40, 0.08);
      --radius: 22px;
    }

    body{
      font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      color: var(--text);
      background: linear-gradient(135deg, var(--pastel-1), var(--pastel-2));
      min-height: 100vh;
    }

    /* ====== Common ====== */
    .soft-card{
      background: rgba(255,255,255,0.92);
      border: 1px solid rgba(17,24,39,0.06);
      box-shadow: var(--shadow);
      border-radius: var(--radius);
    }

    .btn-soft{
      border-radius: 999px;
      padding: 10px 16px;
      border: 1px solid rgba(45,108,223,0.15);
      background: rgba(45,108,223,0.08);
      color: var(--primary);
      font-weight: 600;
    }
    .btn-soft:hover{
      background: rgba(45,108,223,0.14);
      color: var(--primary);
    }

    .badge-soft{
      background: rgba(45,108,223,0.10);
      color: var(--primary);
      border: 1px solid rgba(45,108,223,0.12);
      border-radius: 999px;
      padding: 6px 10px;
      font-weight: 600;
      font-size: 12px;
    }

    /* ====== Navbar ====== */
    .navbar{
      background: rgba(255,255,255,0.75) !important;
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(17,24,39,0.06);
    }

    .brand-wrap{
      display:flex;
      align-items:center;
      gap:20px;
    }
    .brand-logo{
      width: 42px;
      height: 42px;
      border-radius: 14px;
      background: linear-gradient(135deg, rgba(45,108,223,0.18), rgba(34,197,94,0.12));
      display:flex;
      align-items:center;
      justify-content:center;
      box-shadow: 0 10px 20px rgba(45,108,223,0.15);
      border: 1px solid rgba(45,108,223,0.10);
    }
	.brand-logo img{
	  height: 65px;
	  width: auto;
	  object-fit: contain;
	}

    .brand-logo i{
      color: var(--primary);
      font-size: 18px;
    }
    .brand-title{
      line-height: 1.1;
    }
    .brand-title strong{
      font-size: 16px;
      display:block;
    }
    .brand-title small{
      color: var(--muted);
      font-size: 12px;
    }

    .nav-link{
      font-weight: 600;
      color: rgba(31,41,55,0.85) !important;
    }
    .nav-link:hover{
      color: var(--primary) !important;
    }

    /* ====== Hero Slider ====== */
    .hero{
      padding: 28px 0 10px 0;
    }

    .hero-slider{
      position: relative;
      overflow: hidden;
      border-radius: 30px;
      box-shadow: var(--shadow);
      border: 1px solid rgba(17,24,39,0.06);
      background: #fff;
    }

    .hero-slide{
      display:none;
      position: relative;
      height: 440px;
      background-size: cover;
      background-position: center;
    }
    .hero-slide.active{
      display:block;
      animation: fadeIn 600ms ease;
    }

    @keyframes fadeIn{
      from {opacity: 0.35; transform: scale(1.01);}
      to {opacity: 1; transform: scale(1);}
    }

    /* overlay gradient */
    .hero-slide::before{
      content:"";
      position:absolute;
      inset:0;
      background: linear-gradient(90deg, rgba(17,24,39,0.65), rgba(17,24,39,0.10));
    }

    /* curved info panel (NOT a box) */
    .hero-info{
      position:absolute;
      left: 26px;
      bottom: 26px;
      max-width: 520px;
      color: #fff;
      padding: 18px 20px;
      border-radius: 26px 26px 26px 8px;
      background: rgba(255,255,255,0.12);
      border: 1px solid rgba(255,255,255,0.18);
      backdrop-filter: blur(10px);
    }
    .hero-info h1{
      font-size: 28px;
      margin: 0 0 6px 0;
      font-weight: 800;
      letter-spacing: 0.2px;
    }
    .hero-info p{
      margin: 0;
      color: rgba(255,255,255,0.90);
      font-size: 14px;
      line-height: 1.5;
    }

    .hero-actions{
      margin-top: 12px;
      display:flex;
      gap:10px;
      flex-wrap: wrap;
    }
    .btn-hero{
      border-radius: 999px;
      padding: 10px 16px;
      font-weight: 700;
      border: 1px solid rgba(255,255,255,0.25);
      background: rgba(255,255,255,0.12);
      color: #fff;
    }
    .btn-hero:hover{
      background: rgba(255,255,255,0.20);
      color:#fff;
    }

    .slider-dots{
      position:absolute;
      right: 18px;
      bottom: 18px;
      display:flex;
      gap:8px;
      z-index: 3;
    }
    .dot{
      width: 10px;
      height: 10px;
      border-radius: 999px;
      background: rgba(255,255,255,0.45);
      border: 1px solid rgba(255,255,255,0.30);
      cursor:pointer;
    }
    .dot.active{
      background: rgba(255,255,255,0.95);
    }

    /* ====== Sections ====== */
    .section-title{
      font-size: 18px;
      font-weight: 800;
      margin: 0 0 6px 0;
    }
    .section-subtitle{
      color: var(--muted);
      margin: 0;
      font-size: 13px;
    }

    .feature-icon{
      width: 44px;
      height: 44px;
      border-radius: 16px;
      display:flex;
      align-items:center;
      justify-content:center;
      background: linear-gradient(135deg, rgba(45,108,223,0.14), rgba(34,197,94,0.10));
      border: 1px solid rgba(45,108,223,0.12);
    }
    .feature-icon i{
      color: var(--primary);
      font-size: 18px;
    }

    /* ====== Footer ====== */
    footer{
      color: rgba(31,41,55,0.75);
    }

    /* ====== Admin Layout ====== */
    #adminPage{
      /*display:none;*/
    }

    .admin-shell{
      display:flex;
      gap: 18px;
      padding: 18px 0;
    }

    .sidebar{
      width: 280px;
      padding: 16px;
      border-radius: var(--radius);
      background: rgba(255,255,255,0.86);
      border: 1px solid rgba(17,24,39,0.06);
      box-shadow: var(--shadow);
      height: calc(100vh - 120px);
      position: sticky;
      top: 90px;
      overflow:auto;
    }

    .sidebar .menu-title{
      font-size: 12px;
      color: var(--muted);
      font-weight: 800;
      letter-spacing: 0.4px;
      text-transform: uppercase;
      margin: 14px 0 8px 0;
    }

    .sidebar a{
      text-decoration:none;
    }

    .side-item{
      display:flex;
      align-items:center;
      gap:10px;
      padding: 10px 12px;
      border-radius: 14px;
      color: rgba(31,41,55,0.85);
      font-weight: 450;
      transition: 0.2s ease;
      font-size : 10pt;
    }
    .side-item:hover{
      background: rgba(45,108,223,0.08);
      color: var(--primary);
    }
    .side-item i{
      font-size : 10pt;
      color: rgba(45,108,223,0.85);
    }

    .admin-main{
      flex: 1;
      min-width: 0;
    }

    .topbar{
      background: rgba(255,255,255,0.75);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(17,24,39,0.06);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 12px 14px;
      display:flex;
      align-items:center;
      justify-content: space-between;
      gap: 12px;
    }

    .search-wrap{
      flex:1;
      max-width: 520px;
    }
    .search-wrap .form-control{
      border-radius: 999px;
      border: 1px solid rgba(17,24,39,0.08);
      background: rgba(255,255,255,0.9);
      padding-left: 42px;
    }
    .search-wrap{
      position:relative;
    }
    .search-wrap i{
      position:absolute;
      left: 14px;
      top: 50%;
      transform: translateY(-50%);
      color: rgba(31,41,55,0.45);
    }

    .profile-btn{
      display:flex;
      align-items:center;
      gap:10px;
      border-radius: 999px;
      padding: 6px 10px;
      border: 1px solid rgba(17,24,39,0.08);
      background: rgba(255,255,255,0.9);
      cursor:pointer;
    }
    .profile-btn img{
      width: 34px;
      height: 34px;
      border-radius: 999px;
      object-fit: cover;
      border: 2px solid rgba(45,108,223,0.18);
    }
    .profile-name{
      font-weight: 800;
      font-size: 13px;
      line-height: 1.1;
    }
    .profile-role{
      font-size: 11px;
      color: var(--muted);
      font-weight: 600;
    }

    .stat-card{
      padding: 16px;
      border-radius: var(--radius);
      background: rgba(255,255,255,0.92);
      border: 1px solid rgba(17,24,39,0.06);
      box-shadow: var(--shadow);
      height: 100%;
    }
    .stat-card .stat-top{
      display:flex;
      align-items:center;
      justify-content: space-between;
      margin-bottom: 10px;
    }
    .stat-card h3{
      font-size: 22px;
      font-weight: 900;
      margin: 0;
    }
    .stat-card p{
      margin: 0;
      color: var(--muted);
      font-size: 12px;
      font-weight: 600;
    }

    .mini-table td, .mini-table th{
      padding: 12px 12px !important;
      vertical-align: middle;
    }

    /* Mobile adjustments */
    @media (max-width: 992px){
      .hero-slide{ height: 380px; }
      /*.sidebar{ display:none; }*/
      .admin-shell{ flex-direction: column; }
      .topbar{ flex-wrap: wrap; }
      .search-wrap{ max-width: 100%; }
    }

    @media (max-width:992px){

    .sidebar{
        position:fixed !important;
        left:-280px !important;
        top:0 !important;
        width:280px !important;
        height:100vh !important;
        padding:16px;
        z-index:9999 !important;
        overflow-y:auto;
        transition:left .3s ease !important;
        margin:0 !important;
    }

    .sidebar.show{
        left:0 !important;
    }

    }
	
/* ====== HERO Curve Style ====== */
.hero-curve{
  border-top-left-radius: 0 !important;
  border-top-right-radius: 0 !important;
}

/* Potong bentuk gambar jadi curve (bukan petak) */
.hero-clip{
  /*border-radius: 34px;*/
  clip-path: polygon(
    0% 0%,
    100% 0%,
    100% 82%,
    75% 92%,
    55% 84%,
    30% 95%,
    0% 88%
  );
}

/* Tambah ruang bawah sebab wave overlay */
.hero-slide{
  height: 470px;
}

/* Info panel jadi lebih organic (curve) */
.hero-info-curve{
  border-radius: 28px 28px 28px 10px;
  background: rgba(17,24,39,0.35);
  border: 1px solid rgba(255,255,255,0.18);
  backdrop-filter: blur(12px);
}

/* Wave bawah untuk nampak premium */
.hero-wave{
  position:absolute;
  left:0;
  right:0;
  bottom:-1px;
  height: 120px;
  z-index: 2;
  pointer-events: none;
}

.hero-wave svg{
  width: 100%;
  height: 100%;
  display:block;
}

/* Pastikan dots atas wave */
.slider-dots{
  z-index: 5;
}

/* Mobile tweak */
@media (max-width: 992px){
  .hero-slide{
    height: 400px;
  }
  .hero-clip{
    clip-path: polygon(
      0% 0%,
      100% 0%,
      100% 85%,
      70% 92%,
      45% 86%,
      20% 95%,
      0% 90%
    );
  }
}

.modal-content{
    border:none;
    border-radius:24px;
    overflow:hidden;
    box-shadow:0 20px 60px rgba(0,0,0,.12);
}

.col-lg-7{
    padding:40px !important;
}

/* LABEL */
.form-label{
    font-size:13px;
    font-weight:700 !important;
    color:#374151;
    margin-bottom:8px;
}

/* INPUT WRAPPER */
.modern-input{
    position:relative;
    margin-bottom:4px;
}

/* INPUT */
.custom-input{
    height:56px;
    border:1px solid #E5E7EB !important;
    border-radius:14px !important;
    padding-left:52px !important;
    padding-right:52px !important;
    font-size:14px;
    background:#fff;
    transition:all .25s ease;
}

.custom-input:focus{
    border-color:#0d6efd !important;
    box-shadow:0 0 0 4px rgba(13,110,253,.10) !important;
}

/* ICON */
.input-icon{
    position:absolute;
    left:18px;
    top:50%;
    transform:translateY(-50%);
    font-size:18px;
    color:#94A3B8;
    z-index:10;
}

/* EYE BUTTON */
.eye-btn{
    position:absolute;
    right:18px;
    top:50%;
    transform:translateY(-50%);
    border:none;
    background:none;
    color:#94A3B8;
    padding:0;
    z-index:10;
}

.eye-btn:hover{
    color:#0d6efd;
}

/* LOGIN BUTTON */
/*.btn-primary{
    height:35px;
    border:none;
    border-radius:14px !important;
    font-weight:700 !important;
    background:linear-gradient(
        135deg,
        #2563eb,
        #0d6efd
    );
}

.btn-primary:hover{
    transform:translateY(-1px);
}*/

/* CHECKBOX */
/*.form-check-input{
    border-radius:5px;
}

.form-check-label{
    color:#6B7280;
}*/

/* FORGOT PASSWORD */
.btn-link{
    font-weight:600 !important;
}

/* TITLE */
h1{
    letter-spacing:-0.5px;
}

.modal-dialog{
    max-width:600px;
}

.modal-content{
    border:none;
    border-radius:20px;
    overflow:hidden;
}

.modal-body{
    padding:0 !important;
}

.col-lg-7{
    width:100%;
}

#loginModal .form-label{
    margin-bottom:8px;
}

#loginModal .mb-3{
    margin-bottom:20px !important;
}
	
  </style>

    <style>
        /*form left menu*/
.side-parent .parent-menu{
    display:flex;
    justify-content:space-between;
    align-items:center;
    font-weight : 600;
    font-size : 11pt;
}

.sub-menu{
    display:none;
    margin-top:4px;
}

.side-parent.active .sub-menu{
    display:block;
}

.sub-menu .side-item{
    padding-left:15px;
    font-size:11pt;
}

.menu-arrow{
    transition:.3s;
}

.side-parent.active .menu-arrow{
    transform:rotate(180deg);
}

.nav-icon{
    width:16px;
    height:16px;
    flex-shrink:0;
}
    </style>
<title>
<%=
    If(Request.Url.Host.ToLower() = "prolesen.mpkluang.gov.my",
                    "PRO-LESEN MPK",
                    "PRO-LESEN MPK (STAGING)")
%>
</title>
   

    <asp:ContentPlaceHolder ID="head" runat="server">

	

    </asp:ContentPlaceHolder>

    <asp:ContentPlaceHolder ID="HeadContent" runat="server">
    </asp:ContentPlaceHolder>

    <!-- CUSTOM CSS WAJIB PALING BAWAH -->
    <link rel="stylesheet" href="~/css/custom-admin.css">

</head>

<body id="bodyTag" runat="server">
    <form id="form1" runat="server">

    <asp:ScriptManager ID="ScriptManager1" runat="server">
    </asp:ScriptManager>

    

    <asp:Label ID="labelsession" runat="server" Text='<%#Session.Item("sessionSystemId") %>'></asp:Label>
        
          <!-- =======================
       NAVBAR (Shared)
        ======================== -->
        <nav class="navbar navbar-expand-lg sticky-top">
        <div class="container">
		    <a class="navbar-brand text-decoration-none" href="/" >
		        <div class="brand-wrap">
			    <div class="brand-logo">
			        <img src="/images/logo.png" alt="Logo">
			    </div>

			    <div class="brand-title">
			        <strong>ProLesen</strong>
			        <small>MPK Kluang</small>
			    </div>
		        </div>
		    </a>


            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
            <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navMenu">
            <ul class="navbar-nav ms-auto gap-lg-2 mt-3 mt-lg-0">
                <li class="nav-item"><a class="nav-link" href="#"><i class="bi bi-journal-text me-1"></i>Manual Pengguna</a></li>
                <li class="nav-item"><a class="nav-link" href="#"><i class="bi bi-journal-check me-1"></i>Manual Pengguna Agensi & Jabatan</a></li>
                <li class="nav-item"><a class="nav-link" href="#"><i class="bi bi-lightning-charge me-1"></i>Pautan Pantas Pengguna</a></li>
                <li class="nav-item"><a class="nav-link" href="#"><i class="bi bi-telephone me-1"></i>Hubungi Kami</a></li>
                <li class="nav-item">

                <% If CInt(Session.Item("sessionUsersId")) = 0 Then %>

                    <a class="nav-link"
                       href="#"
                       onclick="showLoginModal(); return false;">
                        <i class="bi bi-box-arrow-in-right me-1"></i>Log Masuk

                    </a>

                <% Else %>

                    <%--<a class="nav-link"
                       href="/logout">
       
                        <i class="bi bi-box-arrow-right me-1"></i>Log Keluar

                    </a>--%>

                <% End If %>

            </ul>

                <% If CInt(Session.Item("sessionUsersId")) > 0 Then %>
                <div class="dropdown">
                    <div class="profile-btn" data-bs-toggle="dropdown" aria-expanded="false">
                    <%--<img src="https://i.pravatar.cc/100?img=12" alt="Profile">--%>
                    <asp:Image ID="imgProfile" CssClass="avatar-img" runat="server" />
                    <div class="d-none d-md-block">                        
                        <asp:Label ID="lblFullname1" runat="server" CssClass="profile-name"></asp:Label>
                        <div class="profile-role">MPK Kluang</div>
                    </div>
                    <i class="bi bi-chevron-down ms-1 text-muted"></i>
                    </div>

                    <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0" style="border-radius:18px;" runat="server" id="profileInfo">
                    <li>
                        <a class="dropdown-item py-2" href="<%= ResolveUrl("~/administration/userprofile.aspx?p_Id=30&m_Id=36") %>">
                        <i class="bi bi-person-circle me-2"></i>Lihat Profil Pengguna
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item py-2" href="#">
                        <i class="bi bi-bell me-2"></i>Notifikasi
                        <span class="badge text-bg-primary ms-2">3</span>
                        </a>
                    </li>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                        <a class="dropdown-item py-2 text-danger" href="/logout" >
                        <i class="bi bi-box-arrow-right me-2"></i>Log Keluar
                        </a>
                    </li>
                    </ul>
                </div>
                <% End If %>

            </div>
        </div>
        </nav>


      <!-- =======================
           HOMEPAGE (Public)
      ======================== -->
        <%  If CInt(Session.Item("sessionUsersId")) = 0 Then %>

        <main id="homePage">
    <section class="hero">
      <div class="container">
        <section class="hero">
		  <div class="container">
			<div class="hero-slider hero-curve" id="heroSlider">

			  <!-- Slide 1 -->
			  <div class="hero-slide active hero-clip"
				   style="background-image:url('https://images.unsplash.com/photo-1521791055366-0d553872125f?auto=format&fit=crop&w=1800&q=80');">
				<div class="hero-info hero-info-curve">
				  <span class="badge-soft"><i class="bi bi-shield-check me-1"></i>Selamat & Terurus</span>
				  <h1>Permohonan Lesen Lebih Pantas</h1>
				  <p>
					ProLesen membantu pengguna memohon, menyemak status dan mengurus lesen
					dengan lebih mudah secara digital – mesra pengguna & responsif.
				  </p>
				  <div class="hero-actions">
					<button class="btn btn-hero" id="btnQuickLogin1"><i class="bi bi-person-lock me-1"></i>Log Masuk</button>
					<button class="btn btn-hero"><i class="bi bi-info-circle me-1"></i>Ketahui Lebih Lanjut</button>
				  </div>
