				  </p>
				  <div class="hero-actions">
					<button class="btn btn-hero"><i class="bi bi-journal-text me-1"></i>Manual Agensi</button>
					<button class="btn btn-hero"><i class="bi bi-lightning-charge me-1"></i>Pautan Pantas</button>
				  </div>
				</div>
			  </div>

			  <!-- Slide 3 -->
			  <div class="hero-slide hero-clip"
				   style="background-image:url('https://images.unsplash.com/photo-1520607162513-77705c0f0d4a?auto=format&fit=crop&w=1800&q=80');">
				<div class="hero-info hero-info-curve">
				  <span class="badge-soft"><i class="bi bi-graph-up-arrow me-1"></i>Dashboard & Laporan</span>
