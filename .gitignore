################################################################################
# .gitignore untuk projek Visual Studio / Blazor / ASP.NET
################################################################################

# System files
*.swp
*.*~
project.lock.json
.DS_Store
*.pyc
*.config
nupkg/

# Visual Studio Code
.vscode/*
!.vscode/settings.json

# Rider
.idea/

# Visual Studio
.vs/

# Fleet
.fleet/

# Code Rush
.cr/

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results (ignore semua bin & obj dalam mana-mana project)
**/[Bb]in/
**/[Oo]bj/
**/[Oo]ut/
[Dd]ebug*/
[Rr]elease*/
x64/
x86/
build/
bld/

# Publish / Deployment output
**/[Pp]ublish/
**/[Pp]ublished/
**/[Dd]ist/
**/[Oo]utput/

# Logs
msbuild.log
msbuild.err
msbuild.wrn

# Jangan commit Web.config kalau nak kekalkan local setting
/Web.config
/webapp.Web/wwwroot/temp
